#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

resolve_base_ref() {
  if upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
    printf '%s\n' "$upstream_ref"
    return 0
  fi

  if origin_head="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)"; then
    printf '%s\n' "${origin_head#refs/remotes/}"
    return 0
  fi

  if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
    printf '%s\n' "HEAD~1"
    return 0
  fi

  printf '%s\n' "HEAD"
}

BASE_REF="$(resolve_base_ref)"

echo "[team-flow] running guard against base: ${BASE_REF}"
python3 .gstack/scripts/team_flow_guard.py --mode pre-push --base "${BASE_REF}"

echo "[spec-sync] running guard against base: ${BASE_REF}"
python3 .gstack/scripts/spec_sync_guard.py --base "${BASE_REF}"
